# ─── Flask ─────────────────────────────────────────────────────
# Set to 1 for development (auto-reload, debug toolbar). Must be 0 in production.
FLASK_DEBUG=0

# Port the app listens on
PORT=5000

# Secret key for session signing.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_to_a_random_secret_key

# Encryption key for SMTP password storage and other secrets.
# Generate with: python3 -c "import secrets; import base64, hashlib; print(base64.urlsafe_b64encode(hashlib.sha256(secrets.token_bytes(32)).digest()).decode())"
ENCRYPTION_KEY=

# First-run admin password. If unset, a random password is generated and
# written to data_volume/admin_credentials.txt on first startup.
ADMIN_PASSWORD=

# ─── Database ──────────────────────────────────────────────────
# Backend type: "sqlite" (default) or "postgresql"
DB_TYPE=sqlite

# SQLite: database file path (leave empty for default: data_volume/ssl_checker.db)
DB_PATH=

# PostgreSQL: connection parameters (used when DB_TYPE=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vigil
POSTGRES_USER=vigil
POSTGRES_PASSWORD=change_me
POSTGRES_SCHEMA=vigil

# Set to 1 when running behind HTTPS reverse proxy (enables Secure cookie flag)
HTTPS=1

# ─── Timezone ──────────────────────────────────────────────────
# IANA timezone for all timestamps (storage, comparisons, display)
TIMEZONE=Asia/Karachi

# ─── Session ───────────────────────────────────────────────────
# Session cookie lifetime in hours (max 4)
SESSION_LIFETIME_HOURS=4

# ─── Rate limiting ─────────────────────────────────────────────
# Global rate limit: comma-separated list of "<count> per <period>"
RATE_LIMIT_DEFAULT=200 per day,50 per hour

# Login endpoint rate limit
RATE_LIMIT_LOGIN=10 per minute

# ─── Logging ───────────────────────────────────────────────────
# Max log file size in bytes before rotation (default: 5 MB = 5242880)
LOG_MAX_BYTES=5242880

# Number of rotated log files to keep
LOG_BACKUP_COUNT=3

# ─── Check workers ─────────────────────────────────────────────
# ThreadPoolExecutor max_workers for concurrent SSL/WHOIS checks.
# Increase for 100+ domains; decrease on low-memory systems.
CHECK_WORKERS=20

# PostgreSQL connection pool sizing
PG_POOL_MIN=2
PG_POOL_MAX=10

# Data retention: old check results & logs removed after this many days
DATA_RETENTION_DAYS=90

# ─── WHOIS ─────────────────────────────────────────────────────
# WHOIS socket timeout in seconds
WHOIS_TIMEOUT=15

# WHOIS result cache TTL in seconds (0 to disable caching)
WHOIS_CACHE_TTL=300

# WHOIS per-iteration recv timeout in seconds
WHOIS_RECV_TIMEOUT=5

# ─── Webhook Notifications ─────────────────────────────────────
# Slack Incoming Webhook URL (leave empty to disable)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Zulip Incoming Webhook URL (leave empty to disable)
# ZULIP_WEBHOOK_URL=https://yourzulip.zulipchat.com/api/v1/external/webhook?api_key=xxx&stream=ssl-alerts

# ─── Scheduler ─────────────────────────────────────────────────
# Auto-check interval in hours
SCHEDULER_INTERVAL_HOURS=24

# ─── SMTP (overrides DB SMTP settings when set) ────────────────
# SMTP server hostname
SMTP_HOST=

# SMTP server port (587 for STARTTLS, 465 for implicit TLS)
SMTP_PORT=587

# Enable STARTTLS (true/false). Only applies to SMTP_HOST env override.
SMTP_SECURE=true

# SMTP username (usually the email address)
SMTP_USER=

# SMTP password (app password recommended for Gmail/Outlook)
SMTP_PASS=

# Comma-separated list of alert recipient emails
RECIPIENT_MAIL=
